;; (set chicken (repeat 4096 3))
;; (nth chicken 81)

(defun fib (n)
  (if (or (eq n 0) (eq n 1))
      n
    (+ (fib (- n 1)) (fib (- n 2)))))

(set jf (jit fib 1))

(begin
 (@monitor/clear)
 (let (a (car (@monitor/get)))
   (begin 
    (jf 19)
    (- (car (@monitor/get)) a))))

(begin
    (@monitor/clear)
    (let (a (car (@monitor/get)))
      (begin 
       (fib 19)
       (- (car (@monitor/get)) a))))

